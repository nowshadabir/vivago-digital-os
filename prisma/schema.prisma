generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  position  String?
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)
  image     String?
  invoices  Invoice[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthOtp {
  id         Int      @id @default(autoincrement())
  email      String
  purpose    String
  codeHash   String
  payload    String?  @db.LongText
  expiresAt  DateTime
  verifiedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("auth_otp")
}

model Invoice {
  id            Int                @id @default(autoincrement())
  invoiceNumber String             @unique
  clientName    String
  projectName   String
  clientPhone   String
  clientEmail   String
  issuedDate    DateTime
  status        String             @default("Draft")
  paymentMethod String             @default("Bank Transfer")
  paymentType   String             @default("Advance Payment")
  taxRate       Int                @default(0)
  note          String?            @db.LongText
  terms         String?            @db.LongText
  signature     String?            @db.LongText
  createdById   String?
  createdBy     User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("invoice")
}

model InvoiceLineItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  qty         Int
  unitPrice   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("invoice_line_item")
}

model Client {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  number       String
  business     String
  projectCount Int      @default(0)
  totalPaid    Int      @default(0)
  due          Int      @default(0)
  status       String   @default("Active")
  projects     Project[]
  dueRecords   DueRecord[]
  profitLossRecords ProfitLossRecord[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                Int           @id @default(autoincrement())
  name              String
  clientId          Int
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status            String        @default("Planning")
  startDate         DateTime
  estimatedDeadline DateTime
  valuation         Int           @default(0)
  companyCost       Int           @default(0)
  temporaryCost     Int           @default(0)
  credentials       Credential[]
  files             ProjectFile[]
  payments          Payment[]
  dueRecords        DueRecord[]
  profitLossRecords ProfitLossRecord[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Credential {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category     String
  service      String
  endpoint     String
  username     String
  password     String
  reviewDate   DateTime
  status       String   @default("Active")
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProjectFile {
  id           Int      @id @default(autoincrement())
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName     String
  language     String
  sizeKb       Int      @default(0)
  storagePath  String
  fileDate     DateTime
  status       String   @default("Active")
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Payment {
  id                  Int      @id @default(autoincrement())
  date                DateTime
  party               String
  projectId           Int?
  project             Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  purpose             String
  acknowledgement     String?
  method              String
  amount              Int      @default(0)
  flow                String
  costResponsibility  String?
  reimbursementClient String?
  status              String   @default("Completed")
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Reminder {
  id        Int      @id @default(autoincrement())
  title     String
  type      String
  dueDate   String
  dueTime   String
  priority  String   @default("Medium")
  status    String   @default("Pending")
  note      String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reminder")
}

model DueRecord {
  id         Int      @id @default(autoincrement())
  clientId   Int?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId  Int?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  dueDate    DateTime
  amount     Int      @default(0)
  status     String   @default("Upcoming")
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProfitLossRecord {
  id           Int      @id @default(autoincrement())
  clientId     Int
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId    Int
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revenue      Int      @default(0)
  companyCost  Int      @default(0)
  temporaryCost Int     @default(0)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}